# --- LLM (optional; two auth modes, same interface) ---
# pick provider:model in DANDELION_LLM, then supply ONE matching credential below.
DANDELION_LLM=deepseek:deepseek-chat

# (A) Claude subscription (Claude Code OAuth) — for anthropic:/claude: specs
# CLAUDE_CODE_OAUTH_TOKEN=
# (B) any model API key:
DEEPSEEK_API_KEY=
# ANTHROPIC_API_KEY=          # anthropic:/claude: via API key instead of subscription
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# GROQ_API_KEY=

# --- providers ---
DANDELION_RPC_PROVIDER=drpc
DANDELION_SOURCE_PROVIDER=etherscan_v2
DANDELION_ACTIVITY_PROVIDER=hypersync

# --- keys for on-chain data ---
# dRPC: one key, network slug in the path -> https://lb.drpc.live/<slug>/<key>
# dandelion builds the per-chain URL map from this key (see chains.py: drpc_urls).
DRPC_KEY=
ETHERSCAN_API_KEY=
HYPERSYNC_BEARER=
